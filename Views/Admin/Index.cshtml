@{
    ViewBag.Title = "管理后台";
}

<h2>管理后台</h2>

<div class="row">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="card-title">栏目数量</h4>
                <p class="card-text display-4">@ViewBag.CategoryCount</p>
            </div>
            <a href="/Admin/Categories" class="card-footer text-muted">管理栏目</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="card-title">新闻数量</h4>
                <p class="card-text display-4">@ViewBag.NewsCount</p>
            </div>
            <a href="/Admin/NewsManage" class="card-footer text-muted">管理新闻</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="card-title">留言数量</h4>
                <p class="card-text display-4">@ViewBag.CommentCount</p>
            </div>
            <a href="/Admin/CommentAudit" class="card-footer text-muted">审核留言</a>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h4 class="card-title">待审核留言</h4>
                <p class="card-text display-4 text-warning">@ViewBag.PendingCommentCount</p>
            </div>
            <a href="/Admin/CommentAudit" class="card-footer text-muted">立即审核</a>
        </div>
    </div>
</div>
