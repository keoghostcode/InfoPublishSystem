<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>信息发布系统</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">信息发布系统</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">首页</a>
                    </li>
                    @if (Session["Role"]?.ToString() == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin">管理后台</a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ml-auto">
                    @if (Session["UserId"] != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link">欢迎, @Session["UserName"]</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Logout">退出登录</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Register">注册</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">登录</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center py-4 mt-5 bg-light">
        <p>&copy; 2024 信息发布系统</p>
    </footer>
</body>
</html>
